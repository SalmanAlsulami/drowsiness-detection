# Training datasets (large, not needed for serving)
data/
data_submodels/
mrl_data/
yawn_data/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# Version control
.git/
.gitignore

# Python packaging / envs
*.egg-info/
dist/
build/
venv/
.venv/
env/
.env

# Audio files (generated by alert_system.py, not used in web backend)
*.wav

# Evaluation outputs (plots, JSON histories)
outputs/plots/
outputs/models/*_history.json

# Sub-models (web uses only main + yawn)
outputs/models/efficientnetv2s_cbam_small*
outputs/models/efficientnetv2s_cbam_medium*
outputs/models/efficientnetv2s_cbam_large*
outputs/models/majority_voting_weights.json

# Misc
.claude/
*.md
make_architecture_diagram.py
